<!-- views/Registration.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Shrikhand&display=swap" rel="stylesheet">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/admin.css" rel="stylesheet" />
    <title>DIKANA Store - User Registration</title>
</head>
<body>
    <div class="top-bar">
        <a href="/">    <!-- could be /homepage instead of / -->
            <button>Home</button>
        </a>

        <a href="/login">
            <button>Log in</button>
        </a>

        <!-- leads to itself, design choice -->
        <div class="logo">DIKANA</div>
        <a href="/registration">
            <button>Register</button>
        </a>
    </div>
    
    <div class="content text-center">
    <div class="registration-form">
        <form action="/registration" method="POST">
            
            <div class="form-group">
                <label for="username">Username</label>
                <input 
                    type="text" 
                    class="form-control" 
                    id="username" 
                    name="username" 
                    placeholder="Enter username"
                    required
                >
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                    <input 
                        type="password" 
                        class="form-control" 
                        id="password" 
                        name="password" 
                        placeholder="Enter password"
                        required
                    >
                </div>

                <button type="submit" class="btn btn-primary">Register</button>

            </form>
        </div>
    </div>

    
    <footer>
        <div style="text-align: center; padding: 20px; background-color: #b71c1c; color: gold; font-family: 'Shrikhand', cursive;">
            Thank you for visiting DIKANA. Namaste! 🙏
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.7/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>
</body>
</html>

