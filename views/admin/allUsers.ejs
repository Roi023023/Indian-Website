<div class="container mt-5">
    <h1 class="mb-4">All Users</h1>

    <!-- Search Bar -->
    <div class="mb-3">
        <input type="text" id="user-search" class="form-control" placeholder="Search users by username...">
    </div>

    <% if (users.length === 0) { %>
        <p>No users found.</p>
    <% } else { %>

        <table class="table table-bordered table-striped" id="users-table">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Created At</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                <% users.forEach(user => { %>
                    <tr class="user-row">
                        <td class="user-username"><%= user.username %></td>
                        <td><%= user.email %></td>
                        <td>
                            <% if (user.createdAt) { %>
                                <%= user.createdAt.toISOString().split('T')[0] %>
                            <% } else { %>
                                N/A
                            <% } %>
                        </td>
                        <td>
                            <!-- DELETE -->
                            <form action="/admin/users/<%= user._id %>/delete" method="POST" style="display:inline;">
                                <button class="btn btn-sm btn-danger"
                                    onclick="return confirm('Delete this user?')">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <!-- No users found message -->
        <p id="no-users-msg" style="font-weight:bold; display:none;">No users found.</p>

    <% } %>
</div>

<script>
// Search functionality
document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('user-search');
    const userRows = document.querySelectorAll('.user-row');
    const noUsersMsg = document.getElementById('no-users-msg');

    searchInput.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase();
        let anyVisible = false;

        userRows.forEach(row => {
            const username = row.querySelector('.user-username').textContent.toLowerCase();
            if (username.includes(query)) {
                row.style.display = '';
                anyVisible = true;
            } else {
                row.style.display = 'none';
            }
        });

        noUsersMsg.style.display = anyVisible ? 'none' : 'block';
    });
});
</script>